{
  "name": "@wc2026/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/app.ts",
    "start": "tsx --env-file-if-exists=.env src/app.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "build:server": "node scripts/bundle.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "create-table": "tsx scripts/create-table.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "3.1063.0",
    "@aws-sdk/lib-dynamodb": "3.1063.0",
    "@codegenie/serverless-express": "4.16.0",
    "@wc2026/shared": "*",
    "cors": "2.8.6",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "helmet": "8.2.0",
    "web-push": "^3.6.7",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "22.10.2",
    "@types/supertest": "7.2.0",
    "@types/web-push": "^3.6.4",
    "esbuild": "0.28.0",
    "fast-check": "3.23.1",
    "supertest": "7.2.2",
    "tsx": "4.22.4",
    "typescript": "5.7.2",
    "vitest": "4.1.8"
  }
}
