# Copy to .env for local development.
PORT=4000

# DynamoDB
TABLE_NAME=wc2026
# For local dev with DynamoDB Local (docker-compose):
DYNAMODB_ENDPOINT=http://localhost:8000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# Session token signing key (HMAC). Use a long random value. NEVER commit the real one.
SESSION_SIGNING_SECRET=dev-only-change-me-to-a-long-random-string
SESSION_TTL_DAYS=30

# CORS: the frontend origin allowed to call this API.
ALLOWED_ORIGIN=http://localhost:5173

# football-data.org (required for sync). Get a free token at https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=
FOOTBALL_COMPETITION=WC

# Player-level data (squads + goalscorers + top scorer) comes from ESPN's free public API —
# NO key required. See integration/espnClient.ts.
# (API-Football's free plan does NOT cover the 2026 season, so it isn't used. Left here only if you
#  later upgrade to a paid API-Football plan for predictions/odds.)
API_FOOTBALL_KEY=

# Set PERSISTENCE=memory to run without DynamoDB (in-memory store; data lost on restart).
PERSISTENCE=dynamo
