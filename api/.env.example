# Copy to .env for local development.
PORT=4000

# DynamoDB
TABLE_NAME=wc2026
# For local dev with DynamoDB Local (docker-compose):
DYNAMODB_ENDPOINT=http://localhost:8000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# Session token signing key (HMAC). Use a long random value. NEVER commit the real one.
SESSION_SIGNING_SECRET=dev-only-change-me-to-a-long-random-string
SESSION_TTL_DAYS=30

# CORS: the frontend origin allowed to call this API.
ALLOWED_ORIGIN=http://localhost:5173

# football-data.org (required for sync). Get a free token at https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=
FOOTBALL_COMPETITION=WC

# Set PERSISTENCE=memory to run without DynamoDB (in-memory store; data lost on restart).
PERSISTENCE=dynamo
